---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import PostQuoteShare from '../components/PostQuoteShare';
import {
  SITE_AUTHOR,
  SITE_DEFAULT_OG_IMAGE,
  SITE_TITLE,
  SITE_URL,
} from '../consts';

// Support both blog collection entries and markdown pages with frontmatter
type Props = {
  title: string;
  subtitle?: string;
  description: string;
  pubDate?: Date | string;
  updatedDate?: Date | string;
  heroImage?: string;
  tags?: string[];
  frontmatter?: {
    title?: string;
    subtitle?: string;
    description?: string;
    pubDate?: Date | string;
    updatedDate?: Date | string;
    heroImage?: string;
    tags?: string[];
  };
};

const props = Astro.props as Props;
const frontmatter = props.frontmatter ?? {};
const resolved = {
  ...frontmatter,
  ...props,
};
const title = resolved.title ?? 'Untitled';
const subtitle = resolved.subtitle;
const description = resolved.description ?? '';
const heroImage = resolved.heroImage;
const tags = resolved.tags ?? [];

// Handle both Date objects and string dates, with proper fallback
const rawPubDate = resolved.pubDate;
const rawUpdatedDate = resolved.updatedDate;

const pubDate = rawPubDate 
  ? (typeof rawPubDate === 'string' ? new Date(rawPubDate) : rawPubDate)
  : new Date(); // Fallback to current date if missing

const updatedDate = rawUpdatedDate 
  ? (typeof rawUpdatedDate === 'string' ? new Date(rawUpdatedDate) : rawUpdatedDate)
  : undefined;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: [new URL(heroImage ?? SITE_DEFAULT_OG_IMAGE, SITE_URL).toString()],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE_AUTHOR,
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Person',
    name: SITE_AUTHOR,
    url: SITE_URL,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.toString(),
  },
  isPartOf: {
    '@type': 'Blog',
    name: SITE_TITLE,
    url: SITE_URL,
  },
};
---

<html lang="en">
<head>
<BaseHead
title={title}
description={description}
image={heroImage}
type="article"
publishedTime={pubDate.toISOString()}
modifiedTime={(updatedDate ?? pubDate).toISOString()}
/>
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<!-- Preload blog fonts -->
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=DM+Mono:wght@400;500&display=swap" />
<style>
main {
width: calc(100% - 2em);
max-width: 100%;
margin: 0;
}
.hero-image {
width: 100%;
}
.hero-image figure {
margin: 0;
}
.hero-image img {
display: block;
margin: 0 auto;
border-radius: 12px;
box-shadow: var(--box-shadow);
transition: opacity var(--transition-base);
}
.hero-image figcaption {
text-align: center;
font-size: 0.85em;
color: rgb(var(--gray));
margin-top: 0.5em;
}
.prose {
width: 720px;
max-width: calc(100% - 2em);
margin: auto;
padding: 1em;
color: rgb(var(--gray-dark));
animation: slideUp 0.4s ease both;
}
.title {
margin-bottom: 1em;
padding: 1em 0;
text-align: center;
line-height: 1;
}
.title h1 {
margin: 0 0 0.5em 0;
}
.date {
margin-bottom: 0.5em;
color: rgb(var(--gray));
font-size: 0.9em;
}
.last-updated-on {
font-style: italic;
}
:global(.prose > p.quote-share-paragraph) {
position: relative;
padding-right: 5.5rem;
scroll-margin-top: 8rem;
transition:
background-color var(--transition-base),
box-shadow var(--transition-base),
padding var(--transition-base);
}
:global(.prose > p.quote-share-highlight) {
background: rgba(var(--accent-rgb), 0.12);
box-shadow: 0 0 0 0.45rem rgba(var(--accent-rgb), 0.12);
border-radius: var(--radius-md);
}
:global(.prose > p.quote-share-paragraph .quote-share-button) {
position: absolute;
top: 0.1rem;
right: 0;
display: inline-flex;
align-items: center;
justify-content: center;
min-width: 4.5rem;
padding: 0.35rem 0.75rem;
border: 1px solid rgba(var(--gray), 0.18);
border-radius: 999px;
background: rgba(var(--surface-elevated), 0.92);
box-shadow: var(--card-shadow);
color: rgb(var(--gray-dark));
font: inherit;
font-size: 0.72rem;
font-weight: 700;
letter-spacing: 0.02em;
cursor: pointer;
opacity: 0;
transform: translateY(0.2rem);
transition:
opacity var(--transition-fast),
transform var(--transition-fast),
border-color var(--transition-fast),
background var(--transition-fast),
color var(--transition-fast);
}
:global(.prose > p.quote-share-paragraph:hover .quote-share-button),
:global(.prose > p.quote-share-paragraph:focus-within .quote-share-button),
:global(.prose > p.quote-share-paragraph .quote-share-button.is-success) {
opacity: 1;
transform: translateY(0);
}
:global(.prose > p.quote-share-paragraph .quote-share-button:hover) {
border-color: rgba(var(--accent-rgb), 0.35);
color: var(--accent);
}
:global(.prose > p.quote-share-paragraph .quote-share-button:focus-visible) {
outline: 2px solid rgba(var(--accent-rgb), 0.4);
outline-offset: 2px;
opacity: 1;
transform: translateY(0);
}
:global(.prose > p.quote-share-paragraph .quote-share-button.is-success) {
background: rgba(var(--accent-rgb), 0.12);
border-color: rgba(var(--accent-rgb), 0.35);
color: var(--accent);
}
@media (max-width: 720px) {
:global(.prose > p.quote-share-paragraph) {
padding-right: 0;
padding-bottom: 0.4rem;
}
:global(.prose > p.quote-share-paragraph .quote-share-button) {
position: static;
margin-top: 0.75rem;
opacity: 1;
transform: none;
}
}
</style>
</head>

<body class="blog-layout">
<Header />
<main>
<article>
<div class="hero-image">
{heroImage && (
<figure>
<img
width={1020}
height={510}
src={heroImage}
alt={title}
loading="lazy"
decoding="async"
/>
</figure>
)}
</div>
<div class="prose">
<div class="title">
{tags.length > 0 && (
<div class="flex flex-wrap gap-2 justify-center mb-4">
  {tags.map((tag) => (
    <span class="font-mono text-xs uppercase tracking-mono text-blog-coral border border-blog-coral/30 px-3 py-1 rounded-full">
      {tag}
    </span>
  ))}
</div>
)}
<div class="date">
<FormattedDate date={pubDate} />
{
updatedDate && (
<div class="last-updated-on">
Last updated on <FormattedDate date={updatedDate} />
</div>
)
}
</div>
<h1>{title}</h1>
{subtitle && (
<p class="font-serif text-xl text-blog-text-dim leading-editorial mb-4">{subtitle}</p>
)}
<hr />
</div>
<PostQuoteShare client:load title={title} pathname={Astro.url.pathname} />
<div class="prose-blog">
<slot />
</div>
</div>
</article>
</main>
<Footer />
</body>
</html>
