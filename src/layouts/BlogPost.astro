---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import PostQuoteShare from '../components/PostQuoteShare';
import {
  SITE_AUTHOR,
  SITE_DEFAULT_OG_IMAGE,
  SITE_TITLE,
  SITE_URL,
} from '../consts';

// Support both blog collection entries (heroImage: ImageMetadata)
// and markdown pages via layout frontmatter (heroImage: string)
type Props = {
  title: string;
  description: string;
  subtitle?: string;
  tags?: string[];
  pubDate?: Date | string;
  updatedDate?: Date | string;
  heroImage?: ImageMetadata | string;
  heroImageOG?: string;
  heroImageAlt?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    subtitle?: string;
    tags?: string[];
    pubDate?: Date | string;
    updatedDate?: Date | string;
    heroImage?: string;
    heroImageOG?: string;
    heroImageAlt?: string;
  };
};

const props = Astro.props as Props;
const frontmatter = props.frontmatter ?? {};
const resolved = {
  ...frontmatter,
  ...props,
};
const title = resolved.title ?? 'Untitled';
const description = resolved.description ?? '';
const subtitle = resolved.subtitle;
const tags = resolved.tags ?? [];
const heroImage = resolved.heroImage;
const heroImageAlt = resolved.heroImageAlt ?? title;

// Resolve a string path for OG/social meta: prefer explicit OG override,
// fall back to the built asset path (ImageMetadata) or the string path.
const heroImageOG = resolved.heroImageOG
  ?? (typeof heroImage === 'object' && heroImage !== null ? heroImage.src : heroImage);

const rawPubDate = resolved.pubDate;
const rawUpdatedDate = resolved.updatedDate;

const pubDate = rawPubDate
  ? (typeof rawPubDate === 'string' ? new Date(rawPubDate) : rawPubDate)
  : new Date();

const updatedDate = rawUpdatedDate
  ? (typeof rawUpdatedDate === 'string' ? new Date(rawUpdatedDate) : rawUpdatedDate)
  : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: [new URL(heroImageOG ?? SITE_DEFAULT_OG_IMAGE, SITE_URL).toString()],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE_AUTHOR,
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Person',
    name: SITE_AUTHOR,
    url: SITE_URL,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.toString(),
  },
  isPartOf: {
    '@type': 'Blog',
    name: SITE_TITLE,
    url: SITE_URL,
  },
};
---

<html lang="en">
<head>
  <BaseHead
    title={title}
    description={description}
    image={heroImageOG}
    type="article"
    publishedTime={pubDate.toISOString()}
    modifiedTime={(updatedDate ?? pubDate).toISOString()}
  />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <style>
    main {
      width: calc(100% - 2em);
      max-width: 100%;
      margin: 0;
      padding: 0;
    }

    /* Hero image with scrim */
    .hero-wrap {
      position: relative;
      width: 100%;
      max-height: 480px;
      overflow: hidden;
    }
    .hero-wrap img {
      display: block;
      width: 100%;
      height: 480px;
      object-fit: cover;
      border-radius: 0;
      filter: brightness(0.55);
    }
    .hero-scrim {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 40%, var(--charcoal) 100%);
    }

    /* Article header */
    .article-header {
      width: 720px;
      max-width: calc(100% - 2em);
      margin: 0 auto;
      padding: 3em 1em 1.5em;
      border-bottom: 1px solid var(--rule);
    }

    .header-meta {
      display: flex;
      align-items: center;
      gap: 1em;
      margin-bottom: 1.5em;
      flex-wrap: wrap;
    }

    .pub-date {
      font-family: var(--font-mono);
      font-size: 0.72em;
      color: var(--text-faint);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4em;
    }

    .article-title {
      font-family: var(--font-display);
      font-size: clamp(2.2rem, 5.5vw, 3.8rem);
      font-weight: 400;
      color: var(--text);
      line-height: 1.1;
      margin: 0 0 0.4em;
      letter-spacing: 0.01em;
    }

    .article-subtitle {
      font-family: var(--font-display);
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      font-weight: 300;
      font-style: italic;
      color: var(--text-dim);
      margin: 0 0 0.5em;
      line-height: 1.4;
    }

    .updated-note {
      font-family: var(--font-mono);
      font-size: 0.7em;
      color: var(--text-faint);
      margin-top: 0.5em;
    }

    /* Prose body */
    .prose {
      width: 720px;
      max-width: calc(100% - 2em);
      margin: 0 auto;
      padding: 2.5em 1em 4em;
      animation: slideUp 0.4s ease both;
    }

    .prose :global(p) {
      color: var(--text);
      line-height: 1.8;
      margin-bottom: 1.6em;
    }

    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4) {
      margin-top: 2.5em;
    }

    .prose :global(a) {
      color: var(--teal);
      border-bottom: 1px solid rgba(58, 184, 160, 0.25);
      transition: border-color var(--transition-fast), color var(--transition-fast);
    }

    .prose :global(a:hover) {
      color: var(--coral);
      border-bottom-color: rgba(232, 112, 90, 0.35);
    }

    /* ── Quote share buttons ── */
    .prose :global(.quote-share-paragraph) {
      position: relative;
    }

    .prose :global(.quote-share-button) {
      position: absolute;
      right: -3.5rem;
      top: 0.1em;
      display: none;
      padding: 0.2em 0.55em;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-faint);
      background: transparent;
      border: 1px solid var(--rule);
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition:
        color var(--transition-fast),
        border-color var(--transition-fast),
        background var(--transition-fast);
      white-space: nowrap;
    }

    .prose :global(.quote-share-button:hover),
    .prose :global(.quote-share-button[data-state="success"]) {
      color: var(--teal);
      border-color: var(--teal);
      background: rgba(58, 184, 160, 0.06);
    }

    .prose :global(.quote-share-paragraph:hover .quote-share-button),
    .prose :global(.quote-share-paragraph.quote-share-active .quote-share-button) {
      display: inline-block;
    }

    .prose :global(.quote-share-highlight) {
      background: rgba(58, 184, 160, 0.08);
      box-shadow: 0 0 0 3px rgba(58, 184, 160, 0.15);
      border-radius: var(--radius-sm);
      transition: background 0.3s ease, box-shadow 0.3s ease;
    }

    @media (max-width: 720px) {
      .prose :global(.quote-share-button) {
        position: static;
        display: none;
        margin-top: 0.5em;
        width: max-content;
      }

      .prose :global(.quote-share-paragraph:hover .quote-share-button),
      .prose :global(.quote-share-paragraph.quote-share-active .quote-share-button) {
        display: block;
      }
    }
  </style>
</head>

<body>
  <Header />
  <main>
    <article>
      {heroImage && (
        <div class="hero-wrap">
          {typeof heroImage === 'object' ? (
            <Image src={heroImage} alt={heroImageAlt} width={1440} height={480} loading="eager" />
          ) : (
            <img src={heroImage} alt={heroImageAlt} width={1440} height={480} loading="eager" decoding="async" />
          )}
          <div class="hero-scrim" aria-hidden="true"></div>
        </div>
      )}

      <header class="article-header">
        <div class="header-meta">
          <span class="pub-date"><FormattedDate date={pubDate} /></span>
          {tags.length > 0 && (
            <div class="tag-row" aria-label="Tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
        <h1 class="article-title">{title}</h1>
        {subtitle && <p class="article-subtitle">{subtitle}</p>}
        {updatedDate && (
          <p class="updated-note">Updated: <FormattedDate date={updatedDate} /></p>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
      <PostQuoteShare client:load title={title} path={Astro.url.pathname} />
    </article>
  </main>
  <Footer />
</body>
</html>
