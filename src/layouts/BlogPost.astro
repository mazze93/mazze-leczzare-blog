---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {
  SITE_AUTHOR,
  SITE_DEFAULT_OG_IMAGE,
  SITE_TITLE,
  SITE_URL,
} from '../consts';

// Support both blog collection entries and markdown pages with frontmatter
type Props = {
  title: string;
  description: string;
  subtitle?: string;
  tags?: string[];
  pubDate?: Date | string;
  updatedDate?: Date | string;
  heroImage?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    subtitle?: string;
    tags?: string[];
    pubDate?: Date | string;
    updatedDate?: Date | string;
    heroImage?: string;
  };
};

const props = Astro.props as Props;
const frontmatter = props.frontmatter ?? {};
const resolved = {
  ...frontmatter,
  ...props,
};
const title = resolved.title ?? 'Untitled';
const description = resolved.description ?? '';
const subtitle = resolved.subtitle;
const tags = resolved.tags ?? [];
const heroImage = resolved.heroImage;

const rawPubDate = resolved.pubDate;
const rawUpdatedDate = resolved.updatedDate;

const pubDate = rawPubDate
  ? (typeof rawPubDate === 'string' ? new Date(rawPubDate) : rawPubDate)
  : new Date();

const updatedDate = rawUpdatedDate
  ? (typeof rawUpdatedDate === 'string' ? new Date(rawUpdatedDate) : rawUpdatedDate)
  : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: [new URL(heroImage ?? SITE_DEFAULT_OG_IMAGE, SITE_URL).toString()],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE_AUTHOR,
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Person',
    name: SITE_AUTHOR,
    url: SITE_URL,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.toString(),
  },
  isPartOf: {
    '@type': 'Blog',
    name: SITE_TITLE,
    url: SITE_URL,
  },
};
---

<html lang="en">
<head>
  <BaseHead
    title={title}
    description={description}
    image={heroImage}
    type="article"
    publishedTime={pubDate.toISOString()}
    modifiedTime={(updatedDate ?? pubDate).toISOString()}
  />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <style>
    main {
      width: calc(100% - 2em);
      max-width: 100%;
      margin: 0;
      padding: 0;
    }

    /* Hero image with scrim */
    .hero-wrap {
      position: relative;
      width: 100%;
      max-height: 480px;
      overflow: hidden;
    }
    .hero-wrap img {
      display: block;
      width: 100%;
      height: 480px;
      object-fit: cover;
      border-radius: 0;
      filter: brightness(0.55);
    }
    .hero-scrim {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 40%, var(--charcoal) 100%);
    }

    /* Article header */
    .article-header {
      width: 720px;
      max-width: calc(100% - 2em);
      margin: 0 auto;
      padding: 3em 1em 1.5em;
      border-bottom: 1px solid var(--rule);
    }

    .header-meta {
      display: flex;
      align-items: center;
      gap: 1em;
      margin-bottom: 1.5em;
      flex-wrap: wrap;
    }

    .pub-date {
      font-family: var(--font-mono);
      font-size: 0.72em;
      color: var(--text-faint);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4em;
    }

    .article-title {
      font-family: var(--font-display);
      font-size: clamp(2.2rem, 5.5vw, 3.8rem);
      font-weight: 400;
      color: var(--text);
      line-height: 1.1;
      margin: 0 0 0.4em;
      letter-spacing: 0.01em;
    }

    .article-subtitle {
      font-family: var(--font-display);
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      font-weight: 300;
      font-style: italic;
      color: var(--text-dim);
      margin: 0 0 0.5em;
      line-height: 1.4;
    }

    .updated-note {
      font-family: var(--font-mono);
      font-size: 0.7em;
      color: var(--text-faint);
      margin-top: 0.5em;
    }

    /* Prose body */
    .prose {
      width: 720px;
      max-width: calc(100% - 2em);
      margin: 0 auto;
      padding: 2.5em 1em 4em;
      animation: slideUp 0.4s ease both;
    }

    .prose :global(p) {
      color: var(--text);
      line-height: 1.8;
      margin-bottom: 1.6em;
    }

    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4) {
      margin-top: 2.5em;
    }

    .prose :global(a) {
      color: var(--teal);
      border-bottom: 1px solid rgba(58, 184, 160, 0.25);
      transition: border-color var(--transition-fast), color var(--transition-fast);
    }

    .prose :global(a:hover) {
      color: var(--coral);
      border-bottom-color: rgba(232, 112, 90, 0.35);
    }
  </style>
</head>

<body>
  <Header />
  <main>
    <article>
      {heroImage && (
        <div class="hero-wrap">
          <img src={heroImage} alt={title} width={1440} height={480} loading="eager" decoding="async" />
          <div class="hero-scrim" aria-hidden="true"></div>
        </div>
      )}

      <header class="article-header">
        <div class="header-meta">
          <span class="pub-date"><FormattedDate date={pubDate} /></span>
          {tags.length > 0 && (
            <div class="tag-row" aria-label="Tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
        <h1 class="article-title">{title}</h1>
        {subtitle && <p class="article-subtitle">{subtitle}</p>}
        {updatedDate && (
          <p class="updated-note">Updated: <FormattedDate date={updatedDate} /></p>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</body>
</html>
