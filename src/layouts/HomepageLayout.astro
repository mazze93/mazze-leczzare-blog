---
/**
 * HomepageLayout — fashion-editorial modern aesthetic
 * Loads homepage.css (Playfair Display + DM Sans + Tailwind utilities)
 * alongside global.css (via BaseHead) for shared tokens.
 * Sets data-layout="homepage" on <body> so CSS remaps the shared
 * --text/--rule/--header-bg vars to the deep editorial navy palette,
 * making Header + Footer auto-adapt with zero component changes.
 */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/homepage.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body data-layout="homepage">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
