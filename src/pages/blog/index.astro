---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Recent essays and field notes from Mazze Leczzare." />
		<style>
			main {
				width: 960px;
			}
			.blog-intro {
				margin-bottom: 2rem;
				padding: 1.5rem 0 1rem;
			}
			.blog-intro h1 {
				margin-bottom: 0.5rem;
			}
			.blog-intro p {
				margin: 0;
				max-width: 42rem;
				color: rgb(var(--gray));
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--text-main));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body class="blog-layout">
		<Header />
		<main>
			<section class="blog-intro">
				<h1 class="font-serif font-light">Field Notes</h1>
				<p class="font-serif text-blog-text-dim">
					Essays, architecture notes, and public working documents from the studio.
				</p>
			</section>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img width={720} height={360} src={post.data.heroImage} alt="" />
									{post.data.tags && post.data.tags.length > 0 && (
										<div class="flex flex-wrap gap-2 mb-2">
											{post.data.tags.map((tag) => (
												<span class="font-mono text-xs uppercase tracking-mono text-blog-coral">
													{tag}
												</span>
											))}
										</div>
									)}
									<h4 class="title font-serif font-light">{post.data.title}</h4>
									{post.data.subtitle && (
										<p class="font-serif text-blog-text-dim text-sm mt-1">{post.data.subtitle}</p>
									)}
									<p class="date font-mono text-xs uppercase tracking-mono">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
