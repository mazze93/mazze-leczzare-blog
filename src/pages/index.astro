---
import HomepageLayout from '../layouts/HomepageLayout.astro';
import BreathingHero from '../components/BreathingHero.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<HomepageLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

  <!-- Hero — environmental breathing canvas -->
  <BreathingHero />

  <!-- Recent writing — editorial post index -->
  {posts.length > 0 && (
    <section class="writing-index" aria-label="Recent writing">
      <div class="index-inner">

        <header class="index-header">
          <span class="index-eyebrow">Recent Writing</span>
          <a href="/blog/" class="index-all-link">All posts →</a>
        </header>

        <ol class="index-list" role="list">
          {posts.map((post, i) => (
            <li class="index-item">
              <a href={`/blog/${post.id}/`} class="index-link">
                <span class="index-num" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="index-body">
                  <span class="index-title">{post.data.title}</span>
                  {post.data.description && (
                    <span class="index-desc">{post.data.description}</span>
                  )}
                </span>
                <span class="index-date">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            </li>
          ))}
        </ol>

      </div>
    </section>
  )}

</HomepageLayout>

<style>
/* ── Writing index ──────────────────────────────────────────────────── */
.writing-index {
  border-top: 1px solid var(--home-rule);
  padding: 4rem 1.5rem 6rem;
}

.index-inner {
  max-width: 1120px;
  margin: 0 auto;
}

.index-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--home-rule);
}

.index-eyebrow {
  font-family: var(--font-home-sans);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--home-text-faint);
}

.index-all-link {
  font-family: var(--font-home-sans);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  color: var(--home-gold);
  text-decoration: none;
  transition: opacity 150ms ease;
}
.index-all-link:hover { opacity: 0.7; }

.index-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.index-item {
  border-bottom: 1px solid var(--home-rule);
}

.index-link {
  display: flex;
  align-items: baseline;
  gap: 1.5rem;
  padding: 1.25rem 0;
  text-decoration: none;
}

.index-num {
  font-family: var(--font-home-sans);
  font-size: 0.62rem;
  color: var(--home-text-faint);
  letter-spacing: 0.06em;
  flex-shrink: 0;
  width: 1.8em;
  transition: color 150ms ease;
}

.index-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.25em;
  min-width: 0;
}

.index-title {
  font-family: var(--font-home-display);
  font-size: clamp(1.05rem, 2.2vw, 1.3rem);
  font-weight: 400;
  color: var(--home-text);
  line-height: 1.2;
  letter-spacing: -0.01em;
  transition: color 150ms ease;
}

.index-desc {
  font-family: var(--font-home-sans);
  font-size: 0.78rem;
  font-weight: 300;
  color: var(--home-text-faint);
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.index-date {
  font-family: var(--font-home-sans);
  font-size: 0.68rem;
  color: var(--home-text-faint);
  letter-spacing: 0.04em;
  flex-shrink: 0;
  white-space: nowrap;
}

.index-link:hover .index-title { color: var(--home-gold); }
.index-link:hover .index-num   { color: var(--home-gold); }

.index-link:focus-visible {
  outline: 2px solid var(--teal);
  outline-offset: 2px;
}

@media (max-width: 640px) {
  .writing-index { padding: 3rem 1rem 4rem; }
  .index-link    { flex-wrap: wrap; gap: 0.5rem; }
  .index-date    { width: 100%; }
  .index-desc    { display: none; }
}
</style>
