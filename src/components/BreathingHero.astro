---
/**
 * BreathingHero.astro
 * Homepage hero: "From Erasure → Signal"
 *
 * Environmental breathing canvas — three zones:
 *   Zone 1 (left): noise particles, white, low opacity, random walk
 *   Zone 2 (center): emergence nodes, teal/magenta, teal connections
 *   Zone 3 (right): signal nodes, teal/amber/white, amber connections
 *
 * Nodes breathe darkness into surrounding space via slow radial gradient
 * pulsation. Mouse/touch interaction pulls nodes toward cursor.
 *
 * Respects prefers-reduced-motion (static gradient fallback).
 * Pauses when tab is hidden.
 */
---

<section class="breathing-hero" aria-label="Site introduction">
  <canvas class="breathing-hero__canvas" aria-hidden="true"></canvas>
  <div class="breathing-hero__content">
    <h1 class="breathing-hero__headline">
      From Erasure <span class="breathing-hero__arrow" aria-label="to">&rarr;</span> Signal
    </h1>
    <p class="breathing-hero__tagline">
      Technology, systems thinking, and the architecture of meaning.
    </p>
    <div class="breathing-hero__actions">
      <a href="/blog/" class="breathing-hero__cta">Read the writing</a>
      <a href="/work/" class="breathing-hero__cta breathing-hero__cta--secondary">Explore the work</a>
    </div>
  </div>
</section>

<style>
  .breathing-hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    align-items: center;
    overflow: hidden;
    background: #0b0d12;
  }

  .breathing-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .breathing-hero__content {
    position: relative;
    z-index: 10;
    text-align: right;
    padding-right: clamp(2rem, 10vw, 8rem);
    padding-left: 2rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: 0;
    width: 100%;
    animation: heroFadeIn 1.2s ease-out both;
  }

  .breathing-hero__headline {
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    color: #f2f4f8;
    margin: 0 0 1rem;
    line-height: 1.05;
  }

  .breathing-hero__arrow {
    color: #2bd3c6;
    filter: drop-shadow(0 0 12px rgba(43, 211, 198, 0.6));
    display: inline-block;
    margin: 0 0.2em;
    transition: transform 0.4s ease;
  }

  .breathing-hero__headline:hover .breathing-hero__arrow {
    transform: translateX(4px);
  }

  .breathing-hero__tagline {
    font-family: var(--font-mono, monospace);
    font-size: clamp(0.9rem, 1.8vw, 1.15rem);
    font-weight: 400;
    letter-spacing: 0.015em;
    color: rgba(242, 244, 248, 0.6);
    line-height: 1.6;
    margin: 0 0 2.5rem;
  }

  .breathing-hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .breathing-hero__cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.2s ease;
  }

  .breathing-hero__cta:not(.breathing-hero__cta--secondary) {
    background: #2bd3c6;
    color: #0b0d12;
  }

  .breathing-hero__cta:not(.breathing-hero__cta--secondary):hover {
    background: #34e8d9;
    box-shadow: 0 4px 20px rgba(43, 211, 198, 0.3);
    transform: translateY(-1px);
  }

  .breathing-hero__cta--secondary {
    background: transparent;
    color: rgba(242, 244, 248, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .breathing-hero__cta--secondary:hover {
    color: #f2f4f8;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .breathing-hero {
      background: linear-gradient(90deg, #0b0d12 0%, #131722 100%);
    }
    .breathing-hero__canvas {
      display: none;
    }
    .breathing-hero__content {
      animation: none;
    }
    .breathing-hero__arrow {
      transition: none;
    }
    .breathing-hero__cta {
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .breathing-hero__content {
      text-align: center;
      padding: 2rem;
      margin: 0 auto;
    }
    .breathing-hero__actions {
      justify-content: center;
      flex-direction: column;
      align-items: center;
    }
    .breathing-hero__cta {
      width: 100%;
      max-width: 16rem;
      text-align: center;
    }
  }
</style>

<script>
  interface NoiseParticle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    opacity: number;
  }

  interface BreathingNode {
    x: number;
    y: number;
    baseX: number;
    baseY: number;
    zone: 2 | 3;
    size: number;
    baseOpacity: number;
    breathPhase: number;
    breathSpeed: number;
    darknessRadius: number;
    color: 'teal' | 'magenta' | 'amber' | 'white';
    colorRgb: string;
  }

  interface NodeConnection {
    node1: BreathingNode;
    node2: BreathingNode;
    opacity: number;
    targetOpacity: number;
    zone: 2 | 3;
    formed: boolean;
    formationDelay: number;
    mouseInfluence: number;
  }

  function initBreathingCanvas() {
    const canvas = document.querySelector<HTMLCanvasElement>('.breathing-hero__canvas');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Skip animation for reduced-motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let width = 0;
    let height = 0;
    let particles: NoiseParticle[] = [];
    let nodes: BreathingNode[] = [];
    let connections: NodeConnection[] = [];
    let mouse = { x: -999, y: -999 };
    let animId = 0;

    function resize() {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
      initSystem();
    }

    function makeNode(x: number, y: number, zone: 2 | 3): BreathingNode {
      const isZone2 = zone === 2;
      let color: BreathingNode['color'];
      if (isZone2) {
        color = Math.random() > 0.5 ? 'teal' : 'magenta';
      } else {
        const r = Math.random();
        color = r < 0.4 ? 'teal' : r < 0.7 ? 'amber' : 'white';
      }
      const colorMap: Record<BreathingNode['color'], string> = {
        teal: '43, 211, 198',
        magenta: '192, 75, 183',
        amber: '244, 162, 97',
        white: '242, 244, 248',
      };
      return {
        x, y, baseX: x, baseY: y, zone,
        size: isZone2 ? Math.random() * 2 + 1.5 : Math.random() * 2.5 + 2,
        baseOpacity: isZone2 ? Math.random() * 0.5 + 0.4 : Math.random() * 0.7 + 0.5,
        breathPhase: Math.random() * Math.PI * 2,
        breathSpeed: 0.0008 + Math.random() * 0.0004,
        darknessRadius: isZone2 ? 80 : 120,
        color,
        colorRgb: colorMap[color],
      };
    }

    function initSystem() {
      particles = [];
      nodes = [];
      connections = [];

      // Zone 1: noise particles (left third)
      for (let i = 0; i < 60; i++) {
        particles.push({
          x: Math.random() * (width / 3),
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.2,
          vy: (Math.random() - 0.5) * 0.2,
          size: Math.random() * 1.5 + 0.5,
          opacity: Math.random() * 0.15 + 0.05,
        });
      }

      // Zone 2: emergence nodes (middle third)
      const zone2Nodes: BreathingNode[] = [];
      for (let i = 0; i < 35; i++) {
        const n = makeNode(
          width / 3 + Math.random() * (width / 3),
          Math.random() * height,
          2
        );
        nodes.push(n);
        zone2Nodes.push(n);
      }
      zone2Nodes.forEach(n => {
        zone2Nodes
          .filter(o => { const dx = n.x - o.x; const dy = n.y - o.y; const d = Math.sqrt(dx*dx + dy*dy); return d < 160 && d > 0; })
          .slice(0, 3)
          .forEach(o => connections.push(makeConnection(n, o, 2)));
      });

      // Zone 3: signal nodes (right third)
      const zone3Nodes: BreathingNode[] = [];
      for (let i = 0; i < 45; i++) {
        const n = makeNode(
          (width / 3) * 2 + Math.random() * (width / 3),
          Math.random() * height,
          3
        );
        nodes.push(n);
        zone3Nodes.push(n);
      }
      zone3Nodes.forEach(n => {
        zone3Nodes
          .filter(o => { const dx = n.x - o.x; const dy = n.y - o.y; const d = Math.sqrt(dx*dx + dy*dy); return d < 180 && d > 0; })
          .slice(0, 4)
          .forEach(o => connections.push(makeConnection(n, o, 3)));
      });
    }

    function makeConnection(node1: BreathingNode, node2: BreathingNode, zone: 2 | 3): NodeConnection {
      return {
        node1, node2, zone,
        opacity: 0,
        targetOpacity: zone === 2 ? Math.random() * 0.2 + 0.1 : Math.random() * 0.35 + 0.2,
        formed: false,
        formationDelay: Math.random() * 4000,
        mouseInfluence: 0,
      };
    }

    function nodeMouseInfluence(n: BreathingNode): number {
      const dx = mouse.x - n.x;
      const dy = mouse.y - n.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      return dist < 150 ? (150 - dist) / 150 : 0;
    }

    function updateParticle(p: NoiseParticle) {
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0) p.x = width / 3;
      if (p.x > width / 3) p.x = 0;
      if (p.y < 0) p.y = height;
      if (p.y > height) p.y = 0;
      p.vx += (Math.random() - 0.5) * 0.015;
      p.vy += (Math.random() - 0.5) * 0.015;
      p.vx *= 0.99;
      p.vy *= 0.99;
    }

    function updateNode(n: BreathingNode) {
      n.breathPhase += n.breathSpeed;
      const dx = mouse.x - n.x;
      const dy = mouse.y - n.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 150) {
        const force = (150 - dist) / 150;
        n.x += dx * force * 0.03;
        n.y += dy * force * 0.03;
      }
      n.x += (n.baseX - n.x) * 0.03;
      n.y += (n.baseY - n.y) * 0.03;
    }

    function drawParticle(p: NoiseParticle) {
      ctx!.fillStyle = `rgba(242, 244, 248, ${p.opacity})`;
      ctx!.beginPath();
      ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx!.fill();
    }

    function drawNode(n: BreathingNode) {
      const breathCycle = Math.sin(n.breathPhase);
      const darknessIntensity = (breathCycle + 1) / 2;

      // Darkness breathing field
      const darkGrad = ctx!.createRadialGradient(n.x, n.y, n.size, n.x, n.y, n.darknessRadius);
      darkGrad.addColorStop(0,   `rgba(11, 13, 18, 0)`);
      darkGrad.addColorStop(0.3, `rgba(11, 13, 18, ${darknessIntensity * 0.15})`);
      darkGrad.addColorStop(0.6, `rgba(11, 13, 18, ${darknessIntensity * 0.25})`);
      darkGrad.addColorStop(1,   `rgba(11, 13, 18, ${darknessIntensity * 0.1})`);
      ctx!.fillStyle = darkGrad;
      ctx!.beginPath();
      ctx!.arc(n.x, n.y, n.darknessRadius, 0, Math.PI * 2);
      ctx!.fill();

      // Glow halo
      const glowSize = n.size * 3;
      const glowGrad = ctx!.createRadialGradient(n.x, n.y, 0, n.x, n.y, glowSize);
      glowGrad.addColorStop(0, `rgba(${n.colorRgb}, ${n.baseOpacity * 0.4})`);
      glowGrad.addColorStop(0.5, `rgba(${n.colorRgb}, ${n.baseOpacity * 0.15})`);
      glowGrad.addColorStop(1, `rgba(${n.colorRgb}, 0)`);
      ctx!.fillStyle = glowGrad;
      ctx!.beginPath();
      ctx!.arc(n.x, n.y, glowSize, 0, Math.PI * 2);
      ctx!.fill();

      // Core dot
      ctx!.fillStyle = `rgba(${n.colorRgb}, ${n.baseOpacity})`;
      ctx!.beginPath();
      ctx!.arc(n.x, n.y, n.size, 0, Math.PI * 2);
      ctx!.fill();
    }

    function updateConnection(c: NodeConnection) {
      if (!c.formed && Date.now() % 12000 > c.formationDelay) c.formed = true;
      if (c.formed) c.opacity += (c.targetOpacity - c.opacity) * 0.015;
      const i1 = nodeMouseInfluence(c.node1);
      const i2 = nodeMouseInfluence(c.node2);
      c.mouseInfluence = Math.max(i1, i2);
    }

    function drawConnection(c: NodeConnection) {
      if (c.opacity < 0.01) return;
      const finalOpacity = c.opacity * (1 + c.mouseInfluence * 1.5);
      const color = c.zone === 2 ? '43, 211, 198' : '244, 162, 97';
      ctx!.strokeStyle = `rgba(${color}, ${finalOpacity})`;
      ctx!.lineWidth = 1 + c.mouseInfluence;
      ctx!.beginPath();
      ctx!.moveTo(c.node1.x, c.node1.y);
      ctx!.lineTo(c.node2.x, c.node2.y);
      ctx!.stroke();
    }

    function animate() {
      animId = requestAnimationFrame(animate);

      // Trail fade (instead of clearRect — creates motion blur)
      ctx!.fillStyle = 'rgba(11, 13, 18, 0.4)';
      ctx!.fillRect(0, 0, width, height);

      particles.forEach(p => { updateParticle(p); drawParticle(p); });
      nodes.forEach(n => updateNode(n));
      connections.forEach(c => { updateConnection(c); drawConnection(c); });
      nodes.forEach(n => drawNode(n));
    }

    function handleVisibility() {
      if (document.hidden) {
        cancelAnimationFrame(animId);
      } else {
        animId = requestAnimationFrame(animate);
      }
    }

    canvas.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    canvas.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });
    canvas.addEventListener('touchmove', (e) => {
      if (e.touches.length > 0) { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; }
    }, { passive: true });

    window.addEventListener('resize', resize);
    document.addEventListener('visibilitychange', handleVisibility);

    resize();
    animId = requestAnimationFrame(animate);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBreathingCanvas);
  } else {
    initBreathingCanvas();
  }
</script>
