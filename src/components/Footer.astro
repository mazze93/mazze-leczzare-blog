---
import { SITE_EMAIL, SITE_GITHUB_URL, SITE_RSS_URL } from '../consts';
const today = new Date();
---

<footer role="contentinfo">
<div class="footer-grid">
<section class="footer-brand" aria-label="Brand">
<p class="footer-tagline">Essays, experiments, and field notes from the edge of science, design, story, and security.</p>
</section>
<section class="footer-nav" aria-label="Footer navigation">
<nav aria-label="Footer links">
<a href="/">Home</a>
<a href="/blog">Blog</a>
<a href="/about">About</a>
<a href="/manifesto">Manifesto</a>
</nav>
</section>
<section class="footer-social" aria-label="Site links">
<div class="social-links">
<a href={SITE_GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
<a href={SITE_RSS_URL}>RSS</a>
<a href={SITE_EMAIL}>Contact</a>
</div>
</section>
</div>
<div class="footer-bottom">
<p>&copy; {today.getFullYear()} Mazze Leczzare. All rights reserved.</p>
</div>
</footer>
<style>
footer {
background: linear-gradient(var(--gray-gradient)) no-repeat;
color: rgb(var(--gray));
padding: 3em 2em 2em;
border-top: 1px solid rgba(var(--line-color), 1);
}
.footer-grid {
display: grid;
grid-template-columns: 2fr 1fr 1fr;
gap: 2em;
max-width: 960px;
margin: 0 auto 2em;
}
.footer-brand {
max-width: 280px;
}
.footer-tagline {
margin: 0;
font-size: 0.95em;
line-height: 1.6;
}
.footer-nav nav {
display: flex;
flex-direction: column;
gap: 0.5em;
}
.footer-nav a {
color: rgb(var(--gray));
text-decoration: none;
font-size: 0.9em;
transition: color var(--transition-fast);
}
.footer-nav a:hover {
color: var(--accent);
}
.social-links {
display: flex;
gap: 0.75em;
}
.social-links a {
padding: 0.5em 0.85em;
border-radius: 999px;
border: 1px solid rgba(var(--gray), 0.16);
background: rgba(var(--surface), 0.72);
color: rgb(var(--gray-dark));
text-decoration: none;
transition: color var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast);
}
.social-links a:hover {
color: var(--accent);
transform: translateY(-2px);
border-color: rgba(var(--accent-rgb), 0.35);
}
.footer-bottom {
text-align: center;
padding-top: 1.5em;
border-top: 1px solid rgba(var(--line-color), 1);
max-width: 960px;
margin: 0 auto;
}
.footer-bottom p {
margin: 0;
font-size: 0.85em;
}
@media (max-width: 768px) {
.footer-grid {
grid-template-columns: 1fr;
gap: 1.5em;
}
.footer-brand {
max-width: 100%;
}
}
</style>
