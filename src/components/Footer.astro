---
import { SITE_EMAIL, SITE_GITHUB_URL } from '../consts';
import Colophon from './Colophon.astro';
const year = new Date().getFullYear();
---

<Colophon compact />
<footer role="contentinfo">
  <div class="footer-inner">
    <div class="footer-col footer-brand">
      <span class="footer-wordmark">Mazze Leczzare</span>
      <p class="footer-desc">Essays, experiments, and field notes from the edge of science, design, story, and security.</p>
    </div>
    <div class="footer-col footer-statement">
      <p class="statement-text">There is a particular tension in work that lives simultaneously inside locked doors and open poems — the knowledge that infrastructure is a kind of literature, that security protocols are a form of care.</p>
    </div>
    <div class="footer-col footer-nav">
      <span class="col-label">Navigation</span>
      <nav aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/blog/">Writing</a>
        <a href="/about/">About</a>
        <a href="/work/">Work</a>
        <a href="/security/">Security</a>
      </nav>
    </div>
    <div class="footer-col footer-links">
      <span class="col-label">Links</span>
      <nav aria-label="External links">
        <a href={SITE_GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={SITE_EMAIL}>Contact</a>
      </nav>
    </div>
  </div>
  <div class="footer-bottom">
    <span class="footer-meta">&copy; {year} Mazze Leczzare</span>
    <span class="footer-sep">·</span>
    <span class="footer-meta">mazzeleczzare.com</span>
    <span class="footer-sep">·</span>
    <span class="footer-meta">Built with Astro</span>
  </div>
</footer>

<style>
footer {
  border-top: 1px solid var(--rule);
  padding: 3em 1.5em 2em;
  background: var(--surface);
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr 1fr;
  gap: 2.5em;
  max-width: 960px;
  margin: 0 auto 2.5em;
}

.footer-wordmark {
  display: block;
  font-family: var(--font-display);
  font-size: 1.1em;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 0.75em;
  letter-spacing: 0.02em;
}

.footer-desc {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--text-dim);
  line-height: 1.7;
  margin: 0;
}

.statement-text {
  font-family: var(--font-serif, Georgia, serif);
  font-size: 0.82rem;
  font-style: italic;
  color: var(--text-dim);
  line-height: 1.75;
  margin: 0;
}

.col-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 1em;
}

.footer-nav nav,
.footer-links nav {
  display: flex;
  flex-direction: column;
  gap: 0.4em;
}

.footer-nav a,
.footer-links a {
  font-family: var(--font-mono);
  font-size: 0.78em;
  color: var(--text-dim);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.footer-nav a:hover,
.footer-links a:hover {
  color: var(--teal);
}

.footer-nav a:focus-visible,
.footer-links a:focus-visible {
  outline: 2px solid var(--teal);
  outline-offset: 2px;
  border-radius: var(--radius-sm);
}

.footer-bottom {
  display: flex;
  align-items: center;
  gap: 0.75em;
  max-width: 960px;
  margin: 0 auto;
  padding-top: 1.5em;
  border-top: 1px solid var(--rule);
}

.footer-meta {
  font-family: var(--font-mono);
  font-size: 0.8125rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.footer-sep {
  color: var(--rule);
  font-size: 0.8125rem;
}

@media (max-width: 860px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }
  .footer-brand { grid-column: 1; }
  .footer-statement { grid-column: 2; }
  .footer-nav { grid-column: 1; }
  .footer-links { grid-column: 2; }
}

@media (max-width: 640px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 2em;
  }
  .footer-brand,
  .footer-statement,
  .footer-nav,
  .footer-links { grid-column: 1; }
  .footer-bottom {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25em;
  }
  .footer-sep { display: none; }
}
</style>
