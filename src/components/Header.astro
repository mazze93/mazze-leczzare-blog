---
import { SITE_TITLE } from '../consts';
---

<header role="banner">
  <nav aria-label="Main navigation">
    <a href="/" class="wordmark" aria-label={`${SITE_TITLE} — home`}>{SITE_TITLE}</a>
    <div class="nav-links">
      <a href="/blog">Writing</a>
      <a href="/about">About</a>
      <a href="/manifesto">Manifesto</a>
    </div>
    <div class="nav-util">
      <a href="https://github.com/mazze93" target="_blank" rel="noopener noreferrer" class="util-link">GitHub</a>
      <a href="/rss.xml" class="util-link">RSS</a>
    </div>
  </nav>
</header>

<style>
header {
  position: sticky;
  top: 0;
  z-index: var(--z-header);
  background: rgba(15, 18, 16, 0.92);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--rule);
}

nav {
  display: flex;
  align-items: center;
  gap: 2em;
  max-width: 960px;
  margin: 0 auto;
  padding: 0 1.5em;
  min-height: 56px;
}

.wordmark {
  font-family: var(--font-display);
  font-size: 1.1em;
  font-weight: 500;
  color: var(--text);
  text-decoration: none;
  letter-spacing: 0.02em;
  flex-shrink: 0;
  transition: color var(--transition-fast);
}

.wordmark:hover {
  color: var(--teal);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25em;
  flex: 1;
}

.nav-links a {
  font-family: var(--font-mono);
  font-size: 0.75em;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-faint);
  text-decoration: none;
  padding: 0.4em 0.7em;
  transition: color var(--transition-fast);
}

.nav-links a:hover,
.nav-links a[aria-current="page"] {
  color: var(--teal);
}

.nav-util {
  display: flex;
  align-items: center;
  gap: 0.5em;
  margin-left: auto;
}

.util-link {
  font-family: var(--font-mono);
  font-size: 0.72em;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-faint);
  text-decoration: none;
  padding: 0.3em 0.6em;
  border: 1px solid var(--rule);
  border-radius: var(--radius-sm);
  transition: color var(--transition-fast), border-color var(--transition-fast);
}

.util-link:hover {
  color: var(--teal);
  border-color: rgba(58, 184, 160, 0.3);
}

@media (max-width: 640px) {
  nav {
    gap: 1em;
    padding: 0 1em;
    min-height: 48px;
    flex-wrap: wrap;
  }
  .nav-util { display: none; }
  .nav-links a { padding: 0.3em 0.5em; }
}
</style>
