---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle';
import { SITE_TITLE } from '../consts';
---

<header role="banner">
<nav aria-label="Main navigation">
<h2><a href="/" aria-label={`${SITE_TITLE} — home`}>{SITE_TITLE}</a></h2>
<div class="internal-links">
<HeaderLink href="/">Home</HeaderLink>
<HeaderLink href="/blog">Blog</HeaderLink>
<HeaderLink href="/contact">Contact</HeaderLink>
<HeaderLink href="/about">About</HeaderLink>
<HeaderLink href="/manifesto">Manifesto</HeaderLink>
</div>
<div class="header-actions">
<div class="social-links" aria-label="Site links">
<a href="https://github.com/mazze93" target="_blank" rel="noopener noreferrer">GitHub</a>
<a href="/rss.xml">RSS</a>
<a href="/contact">Contact</a>
</div>
<ThemeToggle client:load />
</div>
</nav>
</header>
<style>
header {
position: sticky;
top: 0;
z-index: var(--z-header);
margin: 0;
padding: 0 1.5em;
background: rgba(var(--surface-elevated), 0.88);
backdrop-filter: blur(12px);
-webkit-backdrop-filter: blur(12px);
box-shadow: 0 1px 0 rgba(var(--black), 8%);
transition: box-shadow var(--transition-base);
}
header.scrolled {
box-shadow: 0 4px 24px rgba(var(--black), 12%);
}
h2 {
margin: 0;
font-size: 1.1em;
}
h2 a,
h2 a.active {
text-decoration: none;
color: rgb(var(--text-main));
font-weight: 700;
letter-spacing: -0.02em;
transition: color var(--transition-fast);
}
h2 a:hover {
color: var(--accent);
}
nav {
display: flex;
align-items: center;
justify-content: space-between;
gap: 1em;
min-height: 68px;
}
nav a {
padding: 0.5em 0.6em;
color: rgb(var(--gray-dark));
border-bottom: 2px solid transparent;
text-decoration: none;
font-size: 0.95em;
transition: color var(--transition-fast), border-color var(--transition-fast);
}
nav a.active {
text-decoration: none;
border-bottom-color: var(--accent);
color: var(--accent);
}
nav a:hover {
color: var(--accent);
}
.internal-links {
display: flex;
align-items: center;
gap: 0.25em;
}
.social-links,
.social-links a,
.header-actions {
display: flex;
align-items: center;
}
.header-actions {
gap: 0.75em;
}
.social-links {
gap: 0.5em;
}
.social-links a {
padding: 0.45em 0.8em;
border-radius: 999px;
border: 1px solid rgba(var(--gray), 0.18);
background: rgba(var(--surface), 0.72);
color: rgb(var(--gray-dark));
transition: color var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast);
font-size: 0.82em;
letter-spacing: 0.02em;
}
.social-links a:hover {
color: var(--accent);
transform: translateY(-2px);
border-color: rgba(var(--accent-rgb), 0.35);
}
:global(.theme-toggle) {
border: 1px solid rgba(var(--gray), 0.18);
background: rgba(var(--surface), 0.78);
color: rgb(var(--gray-dark));
border-radius: 999px;
padding: 0.55rem 0.95rem;
font: inherit;
font-size: 0.82em;
font-weight: 700;
cursor: pointer;
transition: transform var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
}
:global(.theme-toggle:hover) {
transform: translateY(-1px);
border-color: rgba(var(--accent-rgb), 0.35);
}
:global(.theme-toggle:focus-visible) {
outline: 2px solid rgba(var(--accent-rgb), 0.45);
outline-offset: 2px;
}
@media (max-width: 768px) {
nav {
gap: 0.75em;
align-items: flex-start;
padding: 0.75em 0;
flex-direction: column;
}
.internal-links,
.header-actions {
width: 100%;
justify-content: space-between;
}
.social-links {
gap: 0.4em;
flex-wrap: wrap;
}
}
</style>
<script>
	// Add scrolled class for enhanced shadow on scroll
	const header = document.querySelector('header');
	const controller = new AbortController();
	window.addEventListener(
		'scroll',
		() => {
			if (header) {
				header.classList.toggle('scrolled', window.scrollY > 10);
			}
		},
		{ passive: true, signal: controller.signal },
	);
	// Clean up when the page is hidden (navigation away)
	document.addEventListener('visibilitychange', () => {
		if (document.visibilityState === 'hidden') controller.abort();
	}, { once: true });
</script>
