CONTACT_FROM_EMAIL=contact@mazzeleczzare.com
CONTACT_SUBJECT_PREFIX=Mazze Contact

# ── Required secrets (set via `wrangler secret put` or Cloudflare dashboard) ──
# Plain-text admin password checked by /api/login.
ADMIN_PASSWORD=
# Secret used to sign and verify admin session JWTs (minimum 32 random chars).
JWT_SECRET=

# ── Optional secrets ──────────────────────────────────────────────────────────
# POST validated contact payloads to a webhook or Worker endpoint.
CONTACT_WEBHOOK_URL=
# Full Authorization header value expected by the webhook receiver.
CONTACT_WEBHOOK_AUTH_HEADER=

# ── Cloudflare service bindings (not secrets — configure in wrangler.toml) ────
# SHARE_EVENT_RATE_LIMITER: Cloudflare rate-limiting binding for /api/share-event.
# Declare under [[unsafe.bindings]] in wrangler.toml with type = "ratelimit".
