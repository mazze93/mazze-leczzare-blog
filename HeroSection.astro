---
// src/components/HeroSection.astro
// Environmental breathing canvas hero for homepage/portfolio
// Uses fashion-editorial modern aesthetic (Freight Display, Suisse Intl)

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "From Erasure → Signal",
  subtitle = "Technology, Systems Thinking, and the Architecture of Meaning"
} = Astro.props;
---

<section class="hero-section">
  <canvas id="signal-canvas" class="absolute inset-0 w-full h-full"></canvas>
  <div class="hero-content">
    <h1 class="hero-title">
      {title.split('→').map((part: string, i: number) => (
        <>
          {i > 0 && <span class="arrow">→</span>}
          {part.trim()}
        </>
      ))}
    </h1>
    <p class="hero-subtitle">{subtitle}</p>
  </div>
</section>

<style>
  .hero-section {
    @apply relative w-full h-screen overflow-hidden;
    background: theme('colors.home.charcoal');
  }

  .hero-content {
    @apply relative z-10 text-right max-w-7xl ml-auto mr-0 w-full;
    padding-right: clamp(2rem, 10vw, 8rem);
    display: grid;
    align-items: center;
    height: 100vh;
  }

  .hero-title {
    @apply font-display text-home-white;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 300;
    letter-spacing: theme('letterSpacing.editorial');
    line-height: theme('lineHeight.tight-editorial');
    margin: 0 0 1.5rem 0;
  }

  .arrow {
    @apply inline-block text-home-teal;
    filter: drop-shadow(0 0 16px rgba(43, 211, 198, 0.5));
    margin: 0 0.25em;
  }

  .hero-subtitle {
    @apply font-sans text-home-white/70;
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    font-weight: 400;
    letter-spacing: theme('letterSpacing.technical');
    line-height: theme('lineHeight.relaxed-editorial');
  }

  @media (max-width: 768px) {
    .hero-content {
      @apply text-center mx-auto px-8;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #signal-canvas {
      @apply hidden;
    }

    .hero-section {
      background: linear-gradient(90deg, theme('colors.home.charcoal') 0%, theme('colors.home.indigo') 100%);
    }
  }
</style>

<script>
  const canvas = document.getElementById('signal-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('Canvas not found');
  
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('Canvas context not available');

  let width = 0;
  let height = 0;
  let particles: Particle[] = [];
  let nodes: Node[] = [];
  let connections: Connection[] = [];
  let mouse = { x: 0, y: 0 };

  // Homepage color palette
  const TEAL = { r: 43, g: 211, b: 198 };
  const MAGENTA = { r: 192, g: 75, b: 183 };
  const AMBER = { r: 244, g: 162, b: 97 };

  function resize() {
    width = canvas.width = window.innerWidth;
    height = canvas.height = window.innerHeight;
    initializeSystem();
  }

  class Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    opacity: number;
    zone: number;

    constructor(x: number, y: number, zone: number) {
      this.x = x;
      this.y = y;
      this.vx = (Math.random() - 0.5) * 0.2;
      this.vy = (Math.random() - 0.5) * 0.2;
      this.size = Math.random() * 1.5 + 0.5;
      this.opacity = Math.random() * 0.15 + 0.05;
      this.zone = zone;
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;

      if (this.x < 0) this.x = width / 3;
      if (this.x > width / 3) this.x = 0;
      if (this.y < 0) this.y = height;
      if (this.y > height) this.y = 0;

      this.vx += (Math.random() - 0.5) * 0.015;
      this.vy += (Math.random() - 0.5) * 0.015;
      this.vx *= 0.99;
      this.vy *= 0.99;
    }

    draw() {
      ctx.fillStyle = `rgba(242, 244, 248, ${this.opacity})`;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  class Node {
    x: number;
    y: number;
    baseX: number;
    baseY: number;
    zone: number;
    size: number;
    baseOpacity: number;
    breathPhase: number;
    breathSpeed: number;
    darknessRadius: number;
    color: 'teal' | 'magenta' | 'amber' | 'white';

    constructor(x: number, y: number, zone: number) {
      this.x = x;
      this.y = y;
      this.baseX = x;
      this.baseY = y;
      this.zone = zone;
      this.size = zone === 2 ? Math.random() * 2 + 1.5 : Math.random() * 2.5 + 2;
      this.baseOpacity = zone === 2 ? Math.random() * 0.5 + 0.4 : Math.random() * 0.7 + 0.5;
      
      this.breathPhase = Math.random() * Math.PI * 2;
      this.breathSpeed = 0.0008 + Math.random() * 0.0004;
      this.darknessRadius = zone === 2 ? 80 : 120;
      
      if (zone === 2) {
        this.color = Math.random() > 0.5 ? 'teal' : 'magenta';
      } else {
        const rand = Math.random();
        if (rand < 0.4) this.color = 'teal';
        else if (rand < 0.7) this.color = 'amber';
        else this.color = 'white';
      }
    }

    update(mouseX: number, mouseY: number) {
      this.breathPhase += this.breathSpeed;

      const dx = mouseX - this.x;
      const dy = mouseY - this.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < 150) {
        const force = (150 - dist) / 150;
        this.x += dx * force * 0.03;
        this.y += dy * force * 0.03;
      }

      this.x += (this.baseX - this.x) * 0.03;
      this.y += (this.baseY - this.y) * 0.03;
    }

    draw() {
      const breathCycle = Math.sin(this.breathPhase);
      const darknessIntensity = (breathCycle + 1) / 2;
      
      const darkGradient = ctx.createRadialGradient(
        this.x, this.y, this.size,
        this.x, this.y, this.darknessRadius
      );
      
      darkGradient.addColorStop(0, `rgba(11, 13, 18, 0)`);
      darkGradient.addColorStop(0.3, `rgba(11, 13, 18, ${darknessIntensity * 0.15})`);
      darkGradient.addColorStop(0.6, `rgba(11, 13, 18, ${darknessIntensity * 0.25})`);
      darkGradient.addColorStop(1, `rgba(11, 13, 18, ${darknessIntensity * 0.1})`);
      
      ctx.fillStyle = darkGradient;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.darknessRadius, 0, Math.PI * 2);
      ctx.fill();

      const glowSize = this.size * 3;
      const glowGradient = ctx.createRadialGradient(
        this.x, this.y, 0,
        this.x, this.y, glowSize
      );

      let colorRgb: string;
      if (this.color === 'teal') colorRgb = `${TEAL.r}, ${TEAL.g}, ${TEAL.b}`;
      else if (this.color === 'magenta') colorRgb = `${MAGENTA.r}, ${MAGENTA.g}, ${MAGENTA.b}`;
      else if (this.color === 'amber') colorRgb = `${AMBER.r}, ${AMBER.g}, ${AMBER.b}`;
      else colorRgb = '242, 244, 248';

      glowGradient.addColorStop(0, `rgba(${colorRgb}, ${this.baseOpacity * 0.4})`);
      glowGradient.addColorStop(0.5, `rgba(${colorRgb}, ${this.baseOpacity * 0.15})`);
      glowGradient.addColorStop(1, `rgba(${colorRgb}, 0)`);

      ctx.fillStyle = glowGradient;
      ctx.beginPath();
      ctx.arc(this.x, this.y, glowSize, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = `rgba(${colorRgb}, ${this.baseOpacity})`;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
    }

    getMouseInfluence(mouseX: number, mouseY: number): number {
      const dx = mouseX - this.x;
      const dy = mouseY - this.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      return dist < 150 ? (150 - dist) / 150 : 0;
    }
  }

  class Connection {
    node1: Node;
    node2: Node;
    opacity: number;
    targetOpacity: number;
    zone: number;
    formationDelay: number;
    formed: boolean;
    mouseInfluence: number;

    constructor(node1: Node, node2: Node, zone: number) {
      this.node1 = node1;
      this.node2 = node2;
      this.opacity = 0;
      this.targetOpacity = zone === 2 ? Math.random() * 0.2 + 0.1 : Math.random() * 0.35 + 0.2;
      this.zone = zone;
      this.formationDelay = Math.random() * 4000;
      this.formed = false;
      this.mouseInfluence = 0;
    }

    update(mouseX: number, mouseY: number) {
      if (!this.formed && Date.now() % 12000 > this.formationDelay) {
        this.formed = true;
      }

      if (this.formed) {
        this.opacity += (this.targetOpacity - this.opacity) * 0.015;
      }

      const influence1 = this.node1.getMouseInfluence(mouseX, mouseY);
      const influence2 = this.node2.getMouseInfluence(mouseX, mouseY);
      this.mouseInfluence = Math.max(influence1, influence2);
    }

    draw() {
      if (this.opacity < 0.01) return;

      const finalOpacity = this.opacity * (1 + this.mouseInfluence * 1.5);
      const lineWidth = 1 + this.mouseInfluence * 1;

      ctx.strokeStyle = this.zone === 2
        ? `rgba(${TEAL.r}, ${TEAL.g}, ${TEAL.b}, ${finalOpacity})`
        : `rgba(${AMBER.r}, ${AMBER.g}, ${AMBER.b}, ${finalOpacity})`;
      ctx.lineWidth = lineWidth;
      ctx.beginPath();
      ctx.moveTo(this.node1.x, this.node1.y);
      ctx.lineTo(this.node2.x, this.node2.y);
      ctx.stroke();
    }
  }

  function initializeSystem() {
    particles = [];
    nodes = [];
    connections = [];

    // Zone 1: Noise
    for (let i = 0; i < 60; i++) {
      particles.push(new Particle(
        Math.random() * (width / 3),
        Math.random() * height,
        1
      ));
    }

    // Zone 2: Emergence
    const zone2Nodes: Node[] = [];
    for (let i = 0; i < 35; i++) {
      const node = new Node(
        width / 3 + Math.random() * (width / 3),
        Math.random() * height,
        2
      );
      nodes.push(node);
      zone2Nodes.push(node);
    }

    zone2Nodes.forEach(node => {
      const nearby = zone2Nodes.filter(other => {
        const dx = node.x - other.x;
        const dy = node.y - other.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        return dist < 160 && dist > 0;
      });

      nearby.slice(0, 3).forEach(other => {
        connections.push(new Connection(node, other, 2));
      });
    });

    // Zone 3: Signal
    const zone3Nodes: Node[] = [];
    for (let i = 0; i < 45; i++) {
      const node = new Node(
        (width / 3) * 2 + Math.random() * (width / 3),
        Math.random() * height,
        3
      );
      nodes.push(node);
      zone3Nodes.push(node);
    }

    zone3Nodes.forEach(node => {
      const nearby = zone3Nodes.filter(other => {
        const dx = node.x - other.x;
        const dy = node.y - other.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        return dist < 180 && dist > 0;
      });

      nearby.slice(0, 4).forEach(other => {
        connections.push(new Connection(node, other, 3));
      });
    });
  }

  function animate() {
    ctx.fillStyle = 'rgba(11, 13, 18, 0.4)';
    ctx.fillRect(0, 0, width, height);

    particles.forEach(p => {
      p.update();
      p.draw();
    });

    nodes.forEach(n => n.update(mouse.x, mouse.y));

    connections.forEach(c => {
      c.update(mouse.x, mouse.y);
      c.draw();
    });

    nodes.forEach(n => n.draw());

    requestAnimationFrame(animate);
  }

  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  canvas.addEventListener('touchmove', (e: TouchEvent) => {
    if (e.touches.length > 0) {
      mouse.x = e.touches[0].clientX;
      mouse.y = e.touches[0].clientY;
    }
  });

  window.addEventListener('resize', resize);
  resize();
  animate();

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    canvas.style.display = 'none';
  }
</script>
